* text=auto eol=lf

# Windows command scripts should keep CRLF when added later.
*.bat eol=crlf
*.cmd eol=crlf

# Binary assets must never be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.mp3 binary
*.ogg binary
*.webm binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.zip binary
