{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "axismundi/like-button",
	"version": "0.0.12",
	"title": "Like Button",
	"category": "widgets",
	"icon": "heart",
	"description": "Likes the current projected object as the active Axismundi Actor.",
	"textdomain": "axismundi-activities",
	"attributes": {
		"objectUri": { "type": "string", "default": "" }
	},
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"html": false,
		"interactivity": true,
		"color": { "text": true, "background": true },
		"spacing": { "margin": true, "padding": true }
	},
	"editorScript": "file:./edit.js",
	"style": "file:./style.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js"
}
