{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "axismundi/like-button",
	"version": "0.0.12",
	"title": "Like Button",
	"category": "widgets",
	"icon": "heart",
	"description": "Likes the current projected object as the active Axismundi Actor.",
	"textdomain": "axismundi-activities",
	"attributes": {
		"objectUri": {
			"type": "string",
			"default": ""
		},
		"showLabel": {
			"type": "boolean",
			"default": false
		},
		"showCount": {
			"type": "boolean",
			"default": true
		}
	},
	"usesContext": [
		"postId",
		"postType"
	],
	"supports": {
		"html": false,
		"anchor": true,
		"interactivity": true,
		"color": {
			"gradients": true,
			"text": true,
			"background": true,
			"__experimentalDefaultControls": {
				"text": true
			}
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalFontFamily": true,
			"__experimentalFontWeight": true,
			"__experimentalFontStyle": true,
			"__experimentalTextTransform": true,
			"__experimentalLetterSpacing": true,
			"__experimentalDefaultControls": {
				"fontSize": true
			}
		},
		"shadow": true,
		"__experimentalBorder": {
			"radius": true,
			"color": true,
			"width": true,
			"style": true
		}
	},
	"editorScript": "file:./edit.js",
	"style": "file:./style.css",
	"editorStyle": "file:./style.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js"
}
