{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "axismundi/actor-avatar",
	"version": "0.3.1",
	"title": "Actor Avatar",
	"category": "theme",
	"icon": "admin-users",
	"description": "The avatar of the Actor in context: the current Actor on a profile, or the author resolved through attributedTo on an object. The Actor sibling of Core's Avatar, for identities -- remote and Group Actors included -- that carry no WordPress user ID.",
	"textdomain": "axismundi-actors",
	"usesContext": [ "axismundi/actorId" ],
	"attributes": {
		"size": { "type": "number", "default": 128 },
		"variant": { "type": "string", "default": "profile" },
		"isLink": { "type": "boolean", "default": false },
		"linkTarget": { "type": "string", "default": "_self" },
		"rel": { "type": "string", "attribute": "rel", "default": "" }
	},
	"supports": {
		"html": false,
		"multiple": false,
		"align": true,
		"alignWide": false,
		"shadow": {
			"__experimentalSkipSerialization": true
		},
		"spacing": { "margin": true, "padding": true },
		"filter": { "duotone": true },
		"interactivity": { "clientNavigation": true },
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true,
			"style": true,
			"__experimentalSkipSerialization": true,
			"__experimentalDefaultControls": {
				"radius": true
			}
		}
	},
	"editorScript": "file:./edit.js",
	"style": "file:./style.css",
	"render": "file:./render.php"
}
