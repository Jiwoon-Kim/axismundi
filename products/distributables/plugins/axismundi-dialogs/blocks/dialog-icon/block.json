{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "axismundi/dialog-icon",
	"version": "0.1.0",
	"title": "Dialog Icon",
	"category": "theme",
	"icon": "star-filled",
	"description": "An optional leading icon for a basic dialog header. Placed in a Dialog template part.",
	"keywords": [ "dialog", "icon", "hero" ],
	"textdomain": "axismundi-dialogs",
	"attributes": {
		"icon": { "type": "string", "default": "info" }
	},
	"supports": {
		"html": false,
		"align": false,
		"color": {
			"text": true,
			"background": false
		},
		"spacing": {
			"margin": true
		}
	},
	"example": {
		"attributes": {}
	},
	"editorScript": "file:./edit.js",
	"editorStyle": "file:./style.css",
	"style": "file:./style.css",
	"render": "file:./render.php"
}
