{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "axismundi/sheet",
	"version": "0.1.9",
	"title": "Sheet",
	"category": "theme",
	"icon": "align-pull-right",
	"description": "A trigger button that opens a Material Design 3 side or bottom sheet. The sheet content is a Sheet template part.",
	"keywords": [ "sheet", "drawer", "side sheet", "bottom sheet", "dialog", "offcanvas", "panel" ],
	"textdomain": "axismundi-dialogs",
	"parent": [ "axismundi/dialogs" ],
	"attributes": {
		"templatePart": { "type": "string", "default": "" },
		"title": { "type": "string", "default": "" },
		"variant": { "type": "string", "default": "side" },
		"attachment": { "type": "string", "default": "docked" },
		"edge": { "type": "string", "default": "end" },
		"width": { "type": "string", "default": "medium" },
		"triggerIcon": { "type": "string", "default": "menu" },
		"triggerLabel": { "type": "string", "default": "", "role": "content" },
		"label": { "type": "string", "default": "" },
		"closeOnBackdrop": { "type": "boolean", "default": true },
		"showDragHandle": { "type": "boolean", "default": false },
		"modal": { "type": "boolean", "default": true },
		"scrollMode": { "type": "string", "default": "body" }
	},
	"supports": {
		"html": false,
		"interactivity": true,
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"example": {
		"attributes": {}
	},
	"editorScript": "file:./edit.js",
	"editorStyle": "file:./editor.css",
	"style": "file:./style.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js"
}
