{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "axismundi/object-hashtags",
	"version": "0.1.0",
	"title": "Object Hashtags",
	"category": "theme",
	"icon": "tag",
	"description": "The shared hashtags of the ActivityStreams Object being rendered. The Object sibling of Core's Post Terms: same term links, but resolved for cached remote Objects as well as local ones.",
	"textdomain": "axismundi-object-projections",
	"attributes": {
		"prefix": { "type": "string", "default": "" },
		"suffix": { "type": "string", "default": "" }
	},
	"example": { "viewportWidth": 350 },
	"supports": {
		"anchor": true,
		"html": false,
		"color": {
			"gradients": true,
			"link": true,
			"__experimentalDefaultControls": { "text": true }
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalFontFamily": true,
			"__experimentalFontWeight": true,
			"__experimentalFontStyle": true,
			"__experimentalTextTransform": true,
			"__experimentalTextDecoration": true,
			"__experimentalLetterSpacing": true,
			"__experimentalDefaultControls": { "fontSize": true }
		},
		"interactivity": { "clientNavigation": true },
		"__experimentalBorder": {
			"radius": true,
			"color": true,
			"width": true,
			"style": true
		}
	},
	"styles": [
		{ "name": "inline", "label": "Inline", "isDefault": true },
		{ "name": "tags", "label": "Tags" }
	],
	"editorScript": "file:./edit.js",
	"style": [ "wp-block-post-terms", "axismundi-op-object-view" ],
	"editorStyle": [ "wp-block-post-terms", "axismundi-op-object-view" ],
	"render": "file:./render.php"
}
