{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "axismundi/theme-switcher",
	"version": "0.1.0",
	"title": "Theme Switcher",
	"category": "design",
	"icon": "admin-appearance",
	"description": "Switches between Auto, Light, and Dark theme modes.",
	"keywords": [ "theme", "dark mode", "color scheme", "appearance", "light", "dark" ],
	"textdomain": "axismundi-theme-switcher",
	"example": {
		"attributes": {}
	},
	"supports": {
		"html": false,
		"align": false,
		"interactivity": true,
		"color": {
			"text": true,
			"background": true
		},
		"spacing": {
			"padding": true
		},
		"__experimentalBorder": {
			"radius": true
		}
	},
	"styles": [
		{
			"name": "theme-cycle",
			"label": "Theme cycle"
		}
	],
	"editorScript": "file:./edit.js",
	"editorStyle": "file:./style.css",
	"style": "file:./style.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js"
}
