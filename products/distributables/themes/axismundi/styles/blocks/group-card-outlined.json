{
	"$schema": "https://schemas.wp.org/wp/7.0/theme.json",
	"version": 3,
	"title": "Card (outlined)",
	"slug": "card-outlined",
	"blockTypes": [
		"core/group",
		"core/column"
	],
	"styles": {
		"color": {
			"background": "var:preset|color|surface",
			"text": "var:preset|color|on-surface"
		},
		"border": {
			"color": "var:preset|color|outline-variant",
			"radius": "12px",
			"style": "solid",
			"width": "1px"
		}
	}
}
