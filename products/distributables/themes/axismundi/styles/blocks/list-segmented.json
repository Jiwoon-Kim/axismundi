{
	"$schema": "https://schemas.wp.org/wp/7.0/theme.json",
	"version": 3,
	"title": "Segmented",
	"slug": "list-segmented",
	"blockTypes": [
		"core/list"
	],
	"styles": {
		"css": "&{list-style:none;padding:0;display:flex;flex-direction:column;gap:2px;}& > li{margin:0;padding:16px;background-color:var(--wp--preset--color--surface-container);color:var(--wp--preset--color--on-surface);border-radius:16px;}& > li::marker{content:none;}"
	}
}
