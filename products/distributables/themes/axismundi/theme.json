				{
					"name": "Elevation 1",
					"slug": "elevation-1",
					"shadow": "var(--md-sys-elevation-shadow-level1)"
				},
				{
					"name": "Elevation 2",
					"slug": "elevation-2",
					"shadow": "var(--md-sys-elevation-shadow-level2)"
				},
				{
					"name": "Elevation 3",
					"slug": "elevation-3",
					"shadow": "var(--md-sys-elevation-shadow-level3)"
				},
				{
					"name": "Elevation 4",
					"slug": "elevation-4",
					"shadow": "var(--md-sys-elevation-shadow-level4)"
				},
				{
					"name": "Elevation 5",
					"slug": "elevation-5",
