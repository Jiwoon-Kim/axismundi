{
  "$schema": "https://raw.githubusercontent.com/WordPress/gutenberg/wp/7.0/schemas/json/theme.json",
  "version": 3,
  "title": "Elevated",
  "slug": "elevated",
  "blockTypes": [ "core/button" ],
  "styles": {
    "color": {
      "background": "var(--md-sys-color-surface-container-low)",
      "text": "var(--md-sys-color-primary)"
    },
    "border": {
      "color": "transparent",
      "radius": "var(--comp-button-radius)",
      "style": "solid",
      "width": "0px"
    },
    "shadow": "var(--md-sys-elevation-shadow-level1)"
  }
}
