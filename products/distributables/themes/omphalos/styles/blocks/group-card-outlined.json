{
  "$schema": "https://schemas.wp.org/wp/6.8/theme.json",
  "version": 3,
  "title": "Card (outlined)",
  "slug": "card-outlined",
  "blockTypes": [ "core/group" ],
  "styles": {
    "color": {
      "background": "var(--md-sys-color-surface)",
      "text": "var(--md-sys-color-on-surface)"
    },
    "border": {
      "color": "var(--md-sys-color-outline-variant)",
      "radius": "var(--comp-card-radius)",
      "style": "solid",
      "width": "1px"
    },
    "spacing": {
      "padding": "0px"
    }
  }
}
