{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "settings": {
    "_axismundi_provenance": "v3.6.0 Phase 2A scaffold. Theme-only mode; tokens.css remains source of truth; theme.json is the Gutenberg slug registry and compatibility contract.",
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "645px",
      "wideSize": "1340px"
    },
    "color": {
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "slug": "primary",
          "name": "Primary",
          "color": "var(--md-sys-color-primary)"
        },
        {
          "slug": "on-primary",
          "name": "On Primary",
          "color": "var(--md-sys-color-on-primary)"
        },
        {
          "slug": "primary-container",
          "name": "Primary Container",
          "color": "var(--md-sys-color-primary-container)"
        },
        {
          "slug": "on-primary-container",
          "name": "On Primary Container",
          "color": "var(--md-sys-color-on-primary-container)"
        },
        {
          "slug": "secondary",
          "name": "Secondary",
          "color": "var(--md-sys-color-secondary)"
        },
        {
          "slug": "on-secondary",
          "name": "On Secondary",
          "color": "var(--md-sys-color-on-secondary)"
        },
        {
          "slug": "secondary-container",
          "name": "Secondary Container",
          "color": "var(--md-sys-color-secondary-container)"
        },
        {
          "slug": "on-secondary-container",
          "name": "On Secondary Container",
          "color": "var(--md-sys-color-on-secondary-container)"
        },
        {
          "slug": "tertiary",
          "name": "Tertiary",
          "color": "var(--md-sys-color-tertiary)"
        },
        {
          "slug": "on-tertiary",
          "name": "On Tertiary",
          "color": "var(--md-sys-color-on-tertiary)"
        },
        {
          "slug": "tertiary-container",
          "name": "Tertiary Container",
          "color": "var(--md-sys-color-tertiary-container)"
        },
        {
          "slug": "on-tertiary-container",
          "name": "On Tertiary Container",
          "color": "var(--md-sys-color-on-tertiary-container)"
        },
        {
          "slug": "error",
          "name": "Error",
          "color": "var(--md-sys-color-error)"
        },
        {
          "slug": "on-error",
          "name": "On Error",
          "color": "var(--md-sys-color-on-error)"
        },
        {
          "slug": "error-container",
          "name": "Error Container",
          "color": "var(--md-sys-color-error-container)"
        },
        {
          "slug": "on-error-container",
          "name": "On Error Container",
          "color": "var(--md-sys-color-on-error-container)"
        },
        {
          "slug": "surface",
          "name": "Surface",
          "color": "var(--md-sys-color-surface)"
        },
        {
          "slug": "on-surface",
          "name": "On Surface",
          "color": "var(--md-sys-color-on-surface)"
        },
        {
          "slug": "surface-variant",
          "name": "Surface Variant",
          "color": "var(--md-sys-color-surface-variant)"
        },
        {
          "slug": "on-surface-variant",
          "name": "On Surface Variant",
          "color": "var(--md-sys-color-on-surface-variant)"
        },
        {
          "slug": "background",
          "name": "Background",
          "color": "var(--md-sys-color-background)"
        },
        {
          "slug": "on-background",
          "name": "On Background",
          "color": "var(--md-sys-color-on-background)"
        },
        {
          "slug": "outline",
          "name": "Outline",
          "color": "var(--md-sys-color-outline)"
        },
        {
          "slug": "outline-variant",
          "name": "Outline Variant",
          "color": "var(--md-sys-color-outline-variant)"
        }
      ]
    },
    "typography": {
      "customFontSize": false,
      "defaultFontSizes": false,
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "roboto-flex",
          "name": "Roboto Flex",
          "fontFamily": "\"Roboto Flex\", \"Noto Sans KR\", system-ui, sans-serif",
          "fontFace": [
            {
              "fontFamily": "Roboto Flex",
              "fontStyle": "oblique -10deg 0deg",
              "fontWeight": "100 1000",
              "fontStretch": "25% 151%",
              "src": [
                "file:./assets/fonts/roboto-flex/axismundi-roboto-flex.woff2"
              ]
            }
          ]
        },
        {
          "slug": "noto-sans-kr",
          "name": "Noto Sans KR",
          "fontFamily": "\"Noto Sans KR\", sans-serif",
          "fontFace": [
            {
              "fontFamily": "Noto Sans KR",
              "fontStyle": "normal",
              "fontWeight": "100 900",
              "src": [
                "file:./assets/fonts/noto-sans-kr/axismundi-noto-sans-kr.woff2"
              ]
            }
          ]
        },
        {
          "slug": "roboto-serif",
          "name": "Roboto Serif",
          "fontFamily": "\"Roboto Serif\", \"Noto Serif KR\", Georgia, serif",
          "fontFace": [
            {
              "fontFamily": "Roboto Serif",
              "fontStyle": "normal",
              "fontWeight": "100 900",
              "fontStretch": "50% 150%",
              "src": [
                "file:./assets/fonts/roboto-serif/axismundi-roboto-serif.woff2"
              ]
            }
          ]
        },
        {
          "slug": "noto-serif-kr",
          "name": "Noto Serif KR",
          "fontFamily": "\"Noto Serif KR\", serif",
          "fontFace": [
            {
              "fontFamily": "Noto Serif KR",
              "fontStyle": "normal",
              "fontWeight": "100 900",
              "src": [
                "file:./assets/fonts/noto-serif-kr/axismundi-noto-serif-kr.woff2"
              ]
            }
          ]
        },
        {
          "slug": "roboto-mono",
          "name": "Roboto Mono",
          "fontFamily": "\"Roboto Mono\", monospace",
          "fontFace": [
            {
              "fontFamily": "Roboto Mono",
              "fontStyle": "normal",
              "fontWeight": "100 700",
              "src": [
                "file:./assets/fonts/roboto-mono/axismundi-roboto-mono.woff2"
              ]
            },
            {
              "fontFamily": "Roboto Mono",
              "fontStyle": "italic",
              "fontWeight": "100 700",
              "src": [
                "file:./assets/fonts/roboto-mono/axismundi-roboto-mono-italic.woff2"
              ]
            }
          ]
        }
      ],
      "fontSizes": [
        {
          "slug": "display-large",
          "name": "Display Large",
          "size": "var(--md-sys-typescale-display-large-size)"
        },
        {
          "slug": "display-medium",
          "name": "Display Medium",
          "size": "var(--md-sys-typescale-display-medium-size)"
        },
        {
          "slug": "display-small",
          "name": "Display Small",
          "size": "var(--md-sys-typescale-display-small-size)"
        },
        {
          "slug": "headline-large",
          "name": "Headline Large",
          "size": "var(--md-sys-typescale-headline-large-size)"
        },
        {
          "slug": "headline-medium",
          "name": "Headline Medium",
          "size": "var(--md-sys-typescale-headline-medium-size)"
        },
        {
          "slug": "headline-small",
          "name": "Headline Small",
          "size": "var(--md-sys-typescale-headline-small-size)"
        },
        {
          "slug": "title-large",
          "name": "Title Large",
          "size": "var(--md-sys-typescale-title-large-size)"
        },
        {
          "slug": "title-medium",
          "name": "Title Medium",
          "size": "var(--md-sys-typescale-title-medium-size)"
        },
        {
          "slug": "title-small",
          "name": "Title Small",
          "size": "var(--md-sys-typescale-title-small-size)"
        },
        {
          "slug": "body-large",
          "name": "Body Large",
          "size": "var(--md-sys-typescale-body-large-size)"
        },
        {
          "slug": "body-medium",
          "name": "Body Medium",
          "size": "var(--md-sys-typescale-body-medium-size)"
        },
        {
          "slug": "body-small",
          "name": "Body Small",
          "size": "var(--md-sys-typescale-body-small-size)"
        },
        {
          "slug": "label-large",
          "name": "Label Large",
          "size": "var(--md-sys-typescale-label-large-size)"
        },
        {
          "slug": "label-medium",
          "name": "Label Medium",
          "size": "var(--md-sys-typescale-label-medium-size)"
        },
        {
          "slug": "label-small",
          "name": "Label Small",
          "size": "var(--md-sys-typescale-label-small-size)"
        },
        {
          "slug": "small",
          "name": "Small",
          "size": "var(--md-sys-typescale-body-small-size)"
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "var(--md-sys-typescale-body-medium-size)"
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "var(--md-sys-typescale-title-large-size)"
        },
        {
          "slug": "x-large",
          "name": "X Large",
          "size": "var(--md-sys-typescale-headline-medium-size)"
        },
        {
          "slug": "xx-large",
          "name": "XX Large",
          "size": "var(--md-sys-typescale-headline-large-size)"
        }
      ]
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "blockGap": true,
      "margin": true,
      "padding": true,
      "spacingSizes": [
        {
          "slug": "xs",
          "name": "XS",
          "size": "var(--space-xs)"
        },
        {
          "slug": "sm",
          "name": "SM",
          "size": "var(--space-sm)"
        },
        {
          "slug": "md",
          "name": "MD",
          "size": "var(--space-md)"
        },
        {
          "slug": "lg",
          "name": "LG",
          "size": "var(--space-lg)"
        },
        {
          "slug": "xl",
          "name": "XL",
          "size": "var(--space-xl)"
        },
        {
          "slug": "10",
          "name": "10",
          "size": "var(--space-xs)"
        },
        {
          "slug": "20",
          "name": "20",
          "size": "var(--space-sm)"
        },
        {
          "slug": "30",
          "name": "30",
          "size": "var(--space-md)"
        },
        {
          "slug": "40",
          "name": "40",
          "size": "var(--space-lg)"
        },
        {
          "slug": "50",
          "name": "50",
          "size": "var(--space-xl)"
        },
        {
          "slug": "60",
          "name": "60",
          "size": "calc(var(--space-xl) + var(--space-sm))"
        },
        {
          "slug": "70",
          "name": "70",
          "size": "calc(var(--space-xl) + var(--space-md))"
        },
        {
          "slug": "80",
          "name": "80",
          "size": "calc(var(--space-xl) * 2)"
        }
      ],
      "units": [
        "px",
        "rem",
        "%"
      ]
    },
    "custom": {
      "axismundi": {
        "stateLayer": {
          "hover": "var(--md-sys-state-hover-state-layer-opacity)",
          "focus": "var(--md-sys-state-focus-state-layer-opacity)",
          "pressed": "var(--md-sys-state-pressed-state-layer-opacity)",
          "dragged": "var(--md-sys-state-dragged-state-layer-opacity)"
        },
        "shape": {
          "cornerSmall": "var(--md-sys-shape-corner-small)",
          "cornerMedium": "var(--md-sys-shape-corner-medium)",
          "cornerLarge": "var(--md-sys-shape-corner-large)",
          "cornerFull": "var(--md-sys-shape-corner-full)"
        },
        "motion": {
          "durationFastEffects": "var(--md-sys-motion-curve-fast-effects-duration)",
          "durationDefaultEffects": "var(--md-sys-motion-curve-default-effects-duration)",
          "durationFastSpatial": "var(--md-sys-motion-curve-fast-spatial-duration)",
          "curveFastEffects": "var(--md-sys-motion-curve-fast-effects)",
          "curveDefaultEffects": "var(--md-sys-motion-curve-default-effects)",
          "curveFastSpatial": "var(--md-sys-motion-curve-fast-spatial)"
        },
        "elevation": {
          "level0": "var(--md-sys-elevation-level0)",
          "level1": "var(--md-sys-elevation-level1)",
          "level2": "var(--md-sys-elevation-level2)",
          "level3": "var(--md-sys-elevation-level3)",
          "shadowLevel1": "var(--md-sys-elevation-shadow-level1)",
          "shadowLevel2": "var(--md-sys-elevation-shadow-level2)",
          "shadowLevel3": "var(--md-sys-elevation-shadow-level3)"
        },
        "component": {
          "cardPadding": "var(--comp-card-padding)",
          "cardRadius": "var(--comp-card-radius)",
          "buttonHeight": "var(--comp-button-height)",
          "buttonRadius": "var(--comp-button-radius)",
          "touchTarget": "var(--comp-touch-target)"
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--md-sys-color-background)",
      "text": "var(--md-sys-color-on-background)"
    },
    "spacing": {
      "blockGap": "var(--space-md)",
      "padding": {
        "left": "var:preset|spacing|50",
        "right": "var:preset|spacing|50"
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--roboto-flex)",
      "fontSize": "var(--md-sys-typescale-body-large-size)",
      "lineHeight": "var(--md-sys-typescale-body-large-line-height)"
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}
